[{"id": 1, "chapter": "口腔解剖生理学", "question": "牙体最长的牙根是", "options": ["上颌中切牙", "上颌尖牙", "下颌第一磨牙", "下颌尖牙"], "answer": 1, "explanation": "上颌尖牙牙根最长。"}, {"id": 2, "chapter": "口腔解剖生理学", "question": "恒牙中萌出最早的牙齿是", "options": ["第一磨牙", "中切牙", "侧切牙", "尖牙"], "answer": 0, "explanation": "第一恒磨牙约6岁萌出，称六龄齿。"}, {"id": 3, "chapter": "口腔解剖生理学", "question": "上颌第一磨牙牙合面有几个牙尖", "options": ["3个", "4个", "5个", "6个"], "answer": 1, "explanation": "上颌第一磨牙有4个牙尖。"}, {"id": 4, "chapter": "口腔解剖生理学", "question": "下颌骨最容易骨折的部位是", "options": ["下颌角", "髁突颈部", "颏孔区", "正中联合"], "answer": 1, "explanation": "髁突颈部最薄弱。"}, {"id": 5, "chapter": "口腔解剖生理学", "question": "腮腺导管开口于", "options": ["上颌第一磨牙颊黏膜", "上颌第二磨牙颊黏膜", "下颌第一磨牙颊黏膜", "上颌第二前磨牙颊黏膜"], "answer": 1, "explanation": "腮腺导管开口于上颌第二磨牙对应的颊黏膜。"}, {"id": 6, "chapter": "口腔解剖生理学", "question": "三叉神经的分支不包括", "options": ["眼神经", "上颌神经", "下颌神经", "面神经"], "answer": 3, "explanation": "面神经是第七对脑神经。"}, {"id": 7, "chapter": "口腔解剖生理学", "question": "牙本质小管在牙尖部呈", "options": ["直线排列", "S形弯曲", "放射状", "无规则"], "answer": 1, "explanation": "牙本质小管呈S形弯曲。"}, {"id": 8, "chapter": "口腔解剖生理学", "question": "颞下颌关节盘最薄的部位是", "options": ["前带", "中间带", "后带", "双板区"], "answer": 1, "explanation": "中间带最薄。"}, {"id": 9, "chapter": "口腔解剖生理学", "question": "正常覆牙合是指上前牙覆盖下前牙唇面的", "options": ["1/2以内", "1/3以内", "2/3以内", "切1/3以内"], "answer": 1, "explanation": "正常覆牙合不超过1/3。"}, {"id": 10, "chapter": "口腔解剖生理学", "question": "乳牙共有", "options": ["16颗", "18颗", "20颗", "24颗"], "answer": 2, "explanation": "乳牙共20颗。"}, {"id": 11, "chapter": "口腔解剖生理学", "question": "翼外肌的功能是", "options": ["闭口", "张口", "下颌前伸和侧方运动", "上提下颌骨"], "answer": 2, "explanation": "翼外肌使下颌前伸和侧方运动。"}, {"id": 12, "chapter": "口腔解剖生理学", "question": "牙周膜主纤维束中数量最多的是", "options": ["牙槽嵴组", "水平组", "斜行组", "根尖组"], "answer": 2, "explanation": "斜行组数量最多。"}, {"id": 13, "chapter": "口腔解剖生理学", "question": "舌前2/3的味觉神经是", "options": ["三叉神经", "面神经", "舌咽神经", "舌下神经"], "answer": 1, "explanation": "面神经鼓索支支配舌前2/3味觉。"}, {"id": 14, "chapter": "口腔解剖生理学", "question": "上颌骨支柱系统不包括", "options": 